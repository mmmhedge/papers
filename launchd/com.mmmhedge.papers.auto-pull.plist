<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.mmmhedge.papers.auto-pull</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/marypavlenko/papers/scripts/auto_pull.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/marypavlenko/papers</string>

  <key>StartInterval</key>
  <integer>900</integer>

  <key>StartCalendarInterval</key>
  <array>
    <dict>
      <key>Minute</key>
      <integer>0</integer>
    </dict>
    <dict>
      <key>Minute</key>
      <integer>15</integer>
    </dict>
    <dict>
      <key>Minute</key>
      <integer>30</integer>
    </dict>
    <dict>
      <key>Minute</key>
      <integer>45</integer>
    </dict>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/tmp/papers-auto-pull.log</string>

  <key>StandardErrorPath</key>
  <string>/tmp/papers-auto-pull.err</string>
</dict>
</plist>
